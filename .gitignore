# =============================================================================
# 🦀 CONFIGURAÇÕES DO RUST
# =============================================================================
# Ignora a pasta de compilação (gerada pelo cargo build) que é extremamente pesada
target/
debug/
**/target/

# Ignora arquivos de backup gerados pelo formatador do Rust
**/*.rs.bk

# Ignora arquivos de debug do Windows/Compilador
*.pdb
*.stackdump

# =============================================================================
# 💻 SISTEMAS OPERACIONAIS & FERRAMENTAS
# =============================================================================
.vscode/
.DS_Store
._*
Thumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/